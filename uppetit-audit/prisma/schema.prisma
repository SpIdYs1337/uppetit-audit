generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. ПОЛЬЗОВАТЕЛИ (Сотрудники)
model User {
  id           String      @id @default(cuid())
  login        String      @unique
  phone        String?     @unique
  passwordHash String?  
  inviteToken  String?     @unique 
  role         String      @default("AUDITOR")
  pushSubscription  String?

  
  audits       Audit[]
  visitPlans   VisitPlan[]
  
  // НОВОЕ: Точки, которыми управляет этот пользователь (если он ТУ)
  managedLocations Location[] @relation("LocationToTU")
}

// 2. ТОЧКИ (Магазины)
model Location {
  id         String      @id @default(cuid())
  name       String
  address    String?
  
  // НОВЫЕ ПОЛЯ ДЛЯ АКТИВНОСТИ
  isActive   Boolean     @default(true) // Включена ли точка
  activeFrom DateTime?   // Дата начала проведения чек-листов
  activeTo   DateTime?   // Дата окончания
  
  // ПРИВЯЗКА К ТЕРРИТОРИАЛЬНОМУ УПРАВЛЯЮЩЕМУ (ТУ)
  tuId       String?     // Может быть пустым (точка нераспределена)
  tu         User?       @relation("LocationToTU", fields: [tuId], references: [id], onDelete: SetNull)
  
  audits     Audit[]
  visitPlans VisitPlan[]
}

// 3. ЧЕК-ЛИСТЫ (Шаблоны)
model Checklist {
  id              String   @id @default(cuid())
  title           String
  description     String?
  items           String?  @db.Text 
  redThreshold    Int      @default(70) // Порог красной зоны (в процентах)
  yellowThreshold Int      @default(90) // Порог желтой зоны (в процентах)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  audits          Audit[]  
}

// 4. АУДИТЫ (Результаты проверок)
model Audit {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  score       Int
  maxScore    Int?
  
  shiftEmployees String[]  // Массив имен сотрудников на смене
  generalComment String?   // Необязательный общий комментарий

  // ДОБАВЛЕНО: onDelete: Cascade
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  
  // ДОБАВЛЕНО: onDelete: Cascade
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId  String
  
  // ДОБАВЛЕНО: onDelete: Cascade
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  checklistId String

  answers     Answer[]
}

// 5. ОТВЕТЫ С ФОТО
model Answer {
  id          String  @id @default(cuid())
  auditId     String
  audit       Audit   @relation(fields: [auditId], references: [id], onDelete: Cascade)
  
  zone        String? @default("Основной раздел")
  question    String  
  isOk        Boolean 
  penalty     Int     @default(0) 
  photoBase64 String? 
  comment     String? 
}

// 6. ПЛАНЫ ВИЗИТОВ
model VisitPlan {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  date       DateTime // Запланированная дата
  status     String   @default("PLANNED") // PLANNED (запланировано) или DONE (выполнено)
  createdAt  DateTime @default(now())
}