generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AUDITOR
  TU
}

model User {
  id               String      @id @default(cuid())
  name             String?
  email            String?     @unique
  login            String      @unique
  phone            String?     @unique
  passwordHash     String?  
  inviteToken      String?     @unique 
  role             Role        @default(AUDITOR)
  pushSubscription String?

  audits           Audit[]
  visitPlans       VisitPlan[] @relation("PlanAssignee")
  assignedTasks    VisitPlan[] @relation("PlanAssigner")
  managedLocations Location[]  @relation("LocationToTU")
  locations        Location[]  @relation("LocationTus")
}

model Location {
  id         String      @id @default(cuid())
  name       String
  address    String?
  isActive   Boolean     @default(true) 
  activeFrom DateTime?   
  activeTo   DateTime?
  tuId       String?
  tu         User?       @relation("LocationToTU", fields: [tuId], references: [id], onDelete: SetNull)
  tus        User[]      @relation("LocationTus") 

  audits     Audit[]
  visitPlans VisitPlan[]
}

model Checklist {
  id              String             @id @default(cuid())
  title           String
  description     String?
  redThreshold    Int                @default(70) 
  yellowThreshold Int                @default(90) 
  allowedRoles    Role[]             @default([AUDITOR, TU])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  isArchived      Boolean            @default(false)
  versions        ChecklistVersion[] 
}

model ChecklistVersion {
  id          String          @id @default(cuid())
  checklistId String
  checklist   Checklist       @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  version     Int             @default(1)     
  isActive    Boolean         @default(false) 
  createdAt   DateTime        @default(now())

  items       ChecklistItem[] 
  audits      Audit[]         
}

model ChecklistItem {
  id         String           @id @default(cuid())
  versionId  String
  version    ChecklistVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  text       String
  zone       String?          @default("Основной раздел")
  score      Int              @default(0)
  isCritical Boolean          @default(false)
  order      Int              @default(0) 
  isPhotoRequired Boolean     @default(false)

  answers    Answer[]         
}

model Audit {
  id                 String           @id @default(cuid())
  date               DateTime         @default(now())
  score              Int
  maxScore           Int?
  shiftEmployees     String[]         
  generalComment     String?

  userId             String?
  user               User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  auditorName        String?
  tuName             String?
  locationId         String?
  location           Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationName       String?
  
  checklistVersionId String
  checklistVersion   ChecklistVersion @relation(fields: [checklistVersionId], references: [id], onDelete: Cascade)

  answers            Answer[]

  // ДОБАВЛЕНО: Индексы для сверхбыстрого поиска
  @@index([locationId])
  @@index([userId])
  @@index([date])
}

model Answer {
  id        String         @id @default(cuid())
  auditId   String
  audit     Audit          @relation(fields: [auditId], references: [id], onDelete: Cascade)
  itemId    String?
  item      ChecklistItem? @relation(fields: [itemId], references: [id], onDelete: Cascade)
  zone      String?        @default("Основной раздел")
  question  String?  
  isOk      Boolean 
  penalty   Int            @default(0) 
  photos    String[] 
  comment   String? 
 
  @@index([auditId])
  @@index([itemId])
}

model VisitPlan {
  id         String   @id @default(cuid())
  userId     String   
  user       User     @relation("PlanAssignee", fields: [userId], references: [id], onDelete: Cascade)
  assignerId String?  
  assigner   User?    @relation("PlanAssigner", fields: [assignerId], references: [id], onDelete: SetNull)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  date       DateTime 
  status     String   @default("PLANNED") 
  createdAt  DateTime @default(now())
}